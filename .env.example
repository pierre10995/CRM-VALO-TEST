# ── Base de données ──────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crm_valo

# ── Serveur ─────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── JWT ─────────────────────────────────────────────────────────────
# Obligatoire en production, auto-généré en dev
# JWT_SECRET=change-me-in-production

# ── CORS ────────────────────────────────────────────────────────────
# Séparés par des virgules. Défaut en dev : localhost:5173,localhost:3000
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Supabase ───────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── APIs externes ───────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# RESEND_API_KEY=re_...
# ADMIN_EMAIL=admin@example.com

# ── Seed (mots de passe par défaut des utilisateurs) ────────────────
# SEED_PWD_OCEANE=oceane2026
# SEED_PWD_PIERRE=pierre2026
